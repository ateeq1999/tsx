{
  "id": "add-schema",
  "command": "add:schema",
  "description": "Generate a Drizzle ORM schema table definition",
  "token_estimate": 30,
  "schema": {
    "type": "object",
    "required": ["name"],
    "properties": {
      "name": { "type": "string", "description": "Table name (snake_case)" },
      "fields": {
        "type": "array",
        "description": "Column definitions",
        "items": {
          "type": "object",
          "required": ["name", "type"],
          "properties": {
            "name": { "type": "string" },
            "type": { "type": "string", "enum": ["string", "number", "boolean", "date"] },
            "required": { "type": "boolean", "default": false },
            "unique": { "type": "boolean", "default": false },
            "reference": { "type": "string", "description": "Foreign key table name" }
          }
        }
      },
      "timestamps": { "type": "boolean", "default": true, "description": "Add createdAt/updatedAt" },
      "soft_delete": { "type": "boolean", "default": false, "description": "Add deletedAt" }
    }
  }
}
