{
  "id": "add-middleware",
  "command": "add:middleware",
  "description": "Add a Gin middleware function (auth, logging, rate-limit, CORS)",
  "token_estimate": 20,
  "output_paths": [
    "internal/middleware/{{name | snake_case}}.go"
  ],
  "next_steps": [
    "Apply with `r.Use(middleware.{{name | pascal_case}}())` in your router setup"
  ],
  "schema": {
    "type": "object",
    "required": ["name"],
    "properties": {
      "name": { "type": "string", "description": "Middleware name (e.g. 'Auth', 'RateLimit', 'Logger')" },
      "kind": {
        "type": "string",
        "enum": ["auth", "logger", "cors", "rate_limit", "recovery"],
        "default": "auth",
        "description": "Middleware type to scaffold"
      }
    }
  }
}
