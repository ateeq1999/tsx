  "questions": [
    {
      "topic": "how to create a new page",
      "answer": "Create a page.tsx file in src/app/",
      "steps": [
        {
          "action": "Create page file",
          "code": "mkdir -p src/app/about && touch src/app/about/page.tsx"
        },
        {
          "action": "Export default component",
          "description": "Use default export for page component"
        }
      ],
      "files_affected": ["src/app/**/page.tsx"],
      "dependencies": ["next"]
    },
    {
      "topic": "how to create an API route",
      "answer": "Create a route.ts file in src/app/api/",
      "steps": [
        {
          "action": "Create API directory",
          "code": "mkdir -p src/app/api/users"
        },
        {
          "action": "Create route handler",
          "description": "Export GET, POST, PUT, DELETE functions"
        }
      ],
      "files_affected": ["src/app/api/**/*.ts"],
