    "naming": {
      "files": "kebab-case",
      "components": "PascalCase",
      "functions": "camelCase",
      "variables": "camelCase"
    },
    "patterns": [
      {
        "name": "Auth Export",
        "pattern": "export const auth = createAuth(...)",
        "description": "Better Auth instance"
      }
    ]
  },
