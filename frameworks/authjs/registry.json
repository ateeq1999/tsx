{
  "framework": "Auth.js",
  "version": "5.0.0",
  "slug": "authjs",
  "category": "auth",
  "docs": "https://authjs.dev/getting-started",
  "github": "https://github.com/nextauthjs/next-auth",
  "structure": {
    "root": ".",
    "src": "src"
  },
  "generators": [
    {
      "id": "provider",
      "description": "Create an Auth.js provider config"
    }
  ],
  "conventions": {
    "files": {
      "auth": {
        "pattern": "src/auth.ts",
        "example": "src/auth.ts",
        "description": "Auth.js configuration"
      }
    },
    "naming": {
      "files": "kebab-case",
      "components": "PascalCase",
      "functions": "camelCase",
      "variables": "camelCase"
    },
    "patterns": [
      {
        "name": "Auth Export",
        "pattern": "export const { handlers, auth, signIn, signOut } = NextAuth(...)",
        "description": "Auth.js exports"
      }
    ]
  },
  "injection_points": [],
  "integrations": [
    {
      "package": "@auth/core",
      "install": "npm install @auth/core",
      "setup": [
        {
          "file": "src/auth.ts",
          "template": "auth.ts",
          "description": "Create Auth.js configuration"
        }
      ],
      "patterns": [
        {
          "name": "Provider Config",
          "pattern": "GitHub: { ... }",
          "description": "OAuth provider configuration"
        }
      ]
    }
  ],
  "questions": [
    {
      "topic": "how to setup authentication",
      "answer": "Install @auth/core and create src/auth.ts",
      "steps": [
        {
          "action": "Install Auth.js",
          "code": "npm install @auth/core"
        },
        {
          "action": "Create auth config",
          "description": "Create src/auth.ts with providers"
        }
      ],
      "files_affected": ["src/auth.ts"],
      "dependencies": ["@auth/core"]
    }
  ]
}
