{
  "id": "add-migration",
  "command": "add:migration",
  "description": "Generate a SQLite migration SQL scaffold with UP and DOWN blocks",
  "token_estimate": 18,
  "output_paths": [
    "drizzle/{{name}}.sql"
  ],
  "next_steps": [
    "Run `npx drizzle-kit migrate` to apply the migration"
  ],
  "schema": {
    "type": "object",
    "required": ["name"],
    "properties": {
      "name": {
        "type": "string",
        "description": "Migration name in kebab-case (e.g. 'add-users-table')"
      }
    }
  }
}
