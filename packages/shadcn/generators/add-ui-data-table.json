{
  "id": "add-ui-data-table",
  "command": "add:ui-data-table",
  "description": "Add a shadcn/ui DataTable with columns, pagination, and optional search",
  "token_estimate": 55,
  "output_paths": [
    "components/{{name}}Table.tsx",
    "components/{{name}}Columns.tsx"
  ],
  "next_steps": [
    "Define columns in {{name}}Columns.tsx",
    "Pass data and columns to {{name}}Table",
    "Add server-side pagination with a loader"
  ],
  "schema": {
    "type": "object",
    "required": ["name"],
    "properties": {
      "name": { "type": "string", "description": "Table entity name (e.g. 'User', 'Product')" },
      "searchable": { "type": "boolean", "default": true, "description": "Include a search input above the table" },
      "pagination": { "type": "boolean", "default": true, "description": "Include pagination controls" },
      "selectable": { "type": "boolean", "default": false, "description": "Add row checkbox selection" }
    }
  }
}
