{
  "id": "add-model",
  "command": "add:model",
  "description": "Add a SQLAlchemy ORM model with typed columns",
  "token_estimate": 30,
  "output_paths": [
    "app/models/{{name | snake_case}}.py"
  ],
  "next_steps": [
    "Run `alembic revision --autogenerate -m 'add {{name}}'`",
    "Apply with `alembic upgrade head`"
  ],
  "schema": {
    "type": "object",
    "required": ["name"],
    "properties": {
      "name": { "type": "string", "description": "Model class name (e.g. 'User', 'Product')" },
      "table_name": { "type": "string", "description": "PostgreSQL table name (defaults to snake_case of name)" },
      "timestamps": { "type": "boolean", "default": true, "description": "Add created_at and updated_at columns" },
      "soft_delete": { "type": "boolean", "default": false, "description": "Add deleted_at column for soft deletes" }
    }
  }
}
