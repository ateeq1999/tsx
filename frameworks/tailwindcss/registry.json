{
  "framework": "Tailwind CSS",
  "version": "1.0.0",
  "slug": "tailwindcss",
  "category": "ui",
  "docs": "https://tailwindcss.com",
  "github": "https://github.com/tailwindlabs/tailwindcss",
  "structure": {
    "root": ".",
    "src": "src",
    "config": "tailwind.config.ts"
  },
  "generators": [
    {
      "id": "component",
      "description": "Create a styled component using Tailwind utility classes"
    },
    {
      "id": "theme",
      "description": "Extend the Tailwind theme with custom tokens"
    }
  ],
  "conventions": {
    "files": {
      "config": {
        "pattern": "tailwind.config.ts",
        "example": "tailwind.config.ts",
        "description": "Tailwind configuration file"
      },
      "component": {
        "pattern": "src/components/{{pascalCase name}}.tsx",
        "example": "src/components/Button.tsx",
        "description": "Tailwind-styled React component"
      }
    },
    "naming": {
      "files": "PascalCase",
      "components": "PascalCase",
      "functions": "camelCase",
      "variables": "camelCase"
    },
    "patterns": [
      {
        "name": "Utility-First",
        "pattern": "className=\"flex items-center gap-2 rounded-md px-4 py-2\"",
        "description": "Compose styles directly with utility classes, avoid custom CSS"
      },
      {
        "name": "Variant with CVA",
        "pattern": "const buttonVariants = cva('base-classes', { variants: { ... } })",
        "description": "Use class-variance-authority for component variant management"
      },
      {
        "name": "Responsive Prefix",
        "pattern": "className=\"w-full md:w-1/2 lg:w-1/3\"",
        "description": "Apply responsive breakpoints using sm/md/lg/xl prefixes"
      },
      {
        "name": "Dark Mode",
        "pattern": "className=\"bg-white dark:bg-gray-900\"",
        "description": "Use dark: prefix for dark mode styles"
      }
    ]
  },
  "injection_points": [
    {
      "id": "global-css",
      "file": "src/app.css",
      "description": "Import Tailwind directives",
      "template": "@tailwind base;\n@tailwind components;\n@tailwind utilities;"
    }
  ],
  "integrations": [
    {
      "package": "tailwindcss",
      "version": "^4.0.0",
      "description": "Tailwind CSS utility framework",
      "install_command": "npm install -D tailwindcss @tailwindcss/vite",
      "config_file": "tailwind.config.ts",
      "steps": [
        "Install tailwindcss and the Vite plugin",
        "Add @tailwindcss/vite to vite.config.ts plugins",
        "Add @import 'tailwindcss' to src/app.css",
        "Start using utility classes in your components"
      ]
    },
    {
      "package": "class-variance-authority",
      "version": "^0.7.0",
      "description": "Type-safe component variant API",
      "install_command": "npm install class-variance-authority",
      "steps": [
        "Import cva from 'class-variance-authority'",
        "Define component variants with cva()",
        "Apply variants via the returned function"
      ]
    },
    {
      "package": "clsx",
      "version": "^2.0.0",
      "description": "Conditional className utility",
      "install_command": "npm install clsx tailwind-merge",
      "steps": [
        "Create a cn() helper: clsx + tailwind-merge",
        "Use cn() to merge conditional Tailwind classes"
      ]
    }
  ],
  "questions": [
    {
      "keywords": ["dark mode", "dark theme"],
      "answer": "Add dark: prefixed classes alongside your base classes. Configure darkMode: 'class' in tailwind.config.ts to toggle via a class on <html>.",
      "example": "className=\"bg-white dark:bg-gray-900 text-gray-900 dark:text-gray-100\""
    },
    {
      "keywords": ["responsive", "mobile", "breakpoint"],
      "answer": "Tailwind uses mobile-first breakpoints. Unprefixed classes apply to all sizes. Use sm:, md:, lg:, xl:, 2xl: to override at larger sizes.",
      "example": "className=\"block md:flex lg:grid\""
    },
    {
      "keywords": ["custom color", "custom token", "extend theme"],
      "answer": "Extend the theme in tailwind.config.ts under theme.extend to add custom colors, spacing, fonts, etc.",
      "example": "theme: { extend: { colors: { brand: '#6366f1' } } }"
    }
  ]
}
