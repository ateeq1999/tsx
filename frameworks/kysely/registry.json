{
  "framework": "Kysely",
  "version": "0.27.0",
  "slug": "kysely",
  "category": "orm",
  "docs": "https://kysely.dev",
  "github": "https://github.com/kysely-org/kysely",
  "structure": {
    "root": ".",
    "db": "db",
    "src": "src"
  },
  "generators": [
    {
      "id": "schema",
      "description": "Generate a Kysely database schema interface"
    },
    {
      "id": "query",
      "description": "Generate a typed Kysely query helper"
    },
    {
      "id": "migration",
      "description": "Generate a Kysely migration file"
    }
  ],
  "conventions": {
    "files": {
      "database-types": {
        "pattern": "db/database.ts",
        "example": "db/database.ts",
        "description": "Central Database interface with all table types"
      },
      "db-instance": {
        "pattern": "db/index.ts",
        "example": "db/index.ts",
        "description": "Kysely instance export"
      },
      "migration": {
        "pattern": "db/migrations/{{timestamp}}_{{snakeCase name}}.ts",
        "example": "db/migrations/20240101_create_users.ts",
        "description": "Kysely migration file"
      },
      "query": {
        "pattern": "db/queries/{{camelCase name}}.ts",
        "example": "db/queries/getProducts.ts",
        "description": "Reusable typed query helper"
      }
    },
    "naming": {
      "tables": "snake_case",
      "columns": "snake_case",
      "interfaces": "PascalCase (e.g. UserTable)"
    },
    "patterns": [
      {
        "name": "Database interface",
        "pattern": "interface Database { users: UserTable; products: ProductTable; }",
        "description": "Maps table names to their row types"
      },
      {
        "name": "Typed query",
        "pattern": "db.selectFrom('users').where('id', '=', id).selectAll().executeTakeFirst()",
        "description": "Fully type-safe SQL query"
      },
      {
        "name": "Migration up",
        "pattern": "await db.schema.createTable('users').addColumn('id', 'integer', c => c.primaryKey()).execute()",
        "description": "Schema migration"
      }
    ]
  },
  "injection_points": [
    {
      "id": "db-instance",
      "file": "db/index.ts",
      "description": "Configure and export Kysely instance with dialect"
    }
  ],
  "integrations": [
    {
      "package": "kysely",
      "install": "npm install kysely",
      "setup": [
        {
          "file": "db/index.ts",
          "template": "import { Kysely, SqliteDialect } from 'kysely';\nimport Database from 'better-sqlite3';\nimport type { Database as DB } from './database';\n\nexport const db = new Kysely<DB>({\n  dialect: new SqliteDialect({ database: new Database('./data.db') }),\n});",
          "description": "Create Kysely instance with SQLite dialect"
        },
        {
          "file": "db/database.ts",
          "template": "import type { ColumnType, Generated } from 'kysely';\n\nexport interface Database {\n  // Add your table interfaces here\n}",
          "description": "Define Database type interface"
        }
      ],
      "patterns": [
        {
          "name": "Select",
          "pattern": "db.selectFrom('table').selectAll().execute()",
          "description": "Basic select query"
        },
        {
          "name": "Insert",
          "pattern": "db.insertInto('table').values({ ... }).returningAll().executeTakeFirstOrThrow()",
          "description": "Insert with returning"
        }
      ]
    },
    {
      "package": "kysely-codegen",
      "install": "npm install -D kysely-codegen",
      "setup": [
        {
          "file": "package.json",
          "template": "\"db:generate\": \"kysely-codegen --dialect sqlite --url ./data.db --out-file db/database.ts\"",
          "description": "Add codegen script to package.json"
        }
      ],
      "patterns": []
    }
  ],
  "questions": [
    {
      "topic": "how do I set up Kysely",
      "answer": "Install kysely, choose a dialect (SQLite/PostgreSQL/MySQL), define a Database interface, then create a Kysely instance.",
      "steps": [
        { "action": "Install", "code": "npm install kysely better-sqlite3" },
        { "action": "Define types", "code": "// db/database.ts: interface Database { users: UserTable; }" },
        { "action": "Create instance", "code": "// db/index.ts: export const db = new Kysely<Database>({ dialect })" }
      ],
      "files_affected": ["db/index.ts", "db/database.ts"],
      "dependencies": ["kysely", "better-sqlite3"],
      "learn_more": ["https://kysely.dev/docs/getting-started"]
    },
    {
      "topic": "how do I run migrations",
      "answer": "Use Kysely's built-in Migrator with migration files in db/migrations/.",
      "steps": [
        { "action": "Create migration file", "code": "// db/migrations/20240101_create_users.ts" },
        { "action": "Use Migrator", "code": "const migrator = new Migrator({ db, provider: new FileMigrationProvider(...) })" },
        { "action": "Run", "code": "await migrator.migrateToLatest()" }
      ],
      "files_affected": ["db/migrations/**/*.ts"],
      "dependencies": ["kysely"],
      "learn_more": ["https://kysely.dev/docs/migrations"]
    }
  ]
}
