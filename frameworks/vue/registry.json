    {
      "topic": "how to create a component",
      "answer": "Create a .vue file in src/components/",
      "steps": [
        {
          "action": "Create component",
          "code": "touch src/components/MyButton.vue"
        }
      ],
      "files_affected": ["src/components/*.vue"],
