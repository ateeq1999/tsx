{
  "id": "drizzle-pg",
  "name": "Drizzle ORM (PostgreSQL)",
  "description": "Drizzle ORM code patterns for PostgreSQL — schema, migrations, and seed files.",
  "category": "orm",
  "author": "drizzle-team",
  "license": "Apache-2.0",
  "docs": "https://orm.drizzle.team",
  "github": "https://github.com/drizzle-team/drizzle-orm",
  "npm_packages": [
    "drizzle-orm"
  ],
  "commands": [
    {
      "id": "add:schema",
      "description": "Generate a Drizzle PG schema table",
      "template": "schema.jinja"
    },
    {
      "id": "add:migration",
      "description": "Run drizzle-kit generate+push",
      "template": ""
    },
    {
      "id": "add:seed",
      "description": "Generate a seed file",
      "template": "seed.jinja"
    }
  ],
  "peer_packages": [
    "drizzle-kit",
    "pg"
  ],
  "tags": [
    "database",
    "orm",
    "postgresql"
  ],
  "version": "1.0.0",
  "stacks": {},
  "template_format": "jinja",
  "tsx_min": "0.1.0"
}