  "questions": [
    {
      "topic": "how to create a component",
      "answer": "Create a .vue file in src/components/ using <script setup lang=\"ts\"> for Composition API.",
      "steps": [
        { "action": "Create file", "code": "touch src/components/MyButton.vue" },
        { "action": "Add script setup", "code": "<script setup lang=\"ts\">\nconst props = defineProps<{ label: string }>()\n</script>" },
        { "action": "Add template", "code": "<template>\n  <button>{{ props.label }}</button>\n</template>" }
      ],
      "files_affected": ["src/components/*.vue"],
      "dependencies": []
    },
    {
      "topic": "how to create a composable",
      "answer": "Create a TypeScript file in src/composables/ starting with 'use'. Composables encapsulate reactive state and logic.",
      "steps": [
        { "action": "Create file", "code": "touch src/composables/useCounter.ts" },
        { "action": "Define composable", "code": "import { ref } from 'vue'\nexport function useCounter() {\n  const count = ref(0)\n  const increment = () => count.value++\n  return { count, increment }\n}" },
        { "action": "Use in component", "code": "const { count, increment } = useCounter()" }
      ],
      "files_affected": ["src/composables/*.ts"],
      "dependencies": []
    },
    {
      "topic": "how to add routing",
      "answer": "Install vue-router, define routes in src/router/index.ts, and mount it in main.ts.",
      "steps": [
        { "action": "Install", "code": "npm install vue-router" },
        { "action": "Create router", "code": "import { createRouter, createWebHistory } from 'vue-router'\nexport const router = createRouter({\n  history: createWebHistory(),\n  routes: [{ path: '/', component: HomeView }]\n})" },
        { "action": "Mount", "code": "app.use(router)" }
      ],
      "files_affected": ["src/router/index.ts", "src/main.ts"],
      "dependencies": ["vue-router"]
    },
    {
      "topic": "how to manage global state",
      "answer": "Use Pinia — Vue's official state management library. Define stores with defineStore using Composition API syntax.",
      "steps": [
        { "action": "Install", "code": "npm install pinia" },
        { "action": "Create store", "code": "export const useUserStore = defineStore('user', () => {\n  const user = ref(null)\n  async function fetchUser(id) { user.value = await getUser(id) }\n  return { user, fetchUser }\n})" },
        { "action": "Use in component", "code": "const store = useUserStore()\nawait store.fetchUser(1)" }
      ],
      "files_affected": ["src/stores/*.ts", "src/main.ts"],
      "dependencies": ["pinia"]
    },
    {
      "topic": "how to emit events from child component",
      "answer": "Use defineEmits to declare typed events and emit them to the parent.",
      "steps": [
        { "action": "Declare emits", "code": "const emit = defineEmits<{ submit: [value: string] }>()" },
        { "action": "Emit event", "code": "emit('submit', inputValue)" },
        { "action": "Listen in parent", "code": "<MyForm @submit=\"handleSubmit\" />" }
      ],
      "files_affected": ["src/components/*.vue"],
      "dependencies": []
    },
    {
      "topic": "how to fetch data from an API",
      "answer": "Use a composable with ref + onMounted, or VueUse's useFetch for reactive data fetching.",
      "steps": [
        { "action": "Create fetch composable", "code": "const data = ref(null)\nconst loading = ref(false)\nonMounted(async () => {\n  loading.value = true\n  data.value = await fetch('/api/items').then(r => r.json())\n  loading.value = false\n})" }
      ],
      "files_affected": ["src/composables/use*.ts"],
      "dependencies": []
    }
  ]
}
