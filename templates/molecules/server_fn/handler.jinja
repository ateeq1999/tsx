{{ "import { createServerFn } from '@tanstack/start/server'" | collect_import }}
{% if auth %}
{{ "import { getSession } from 'lib/auth'" | collect_import_priority }}
{% endif %}

export const {{ name | camel_case }} = createServerFn({
  method: '{{ operation }}',
})
{% if input %}
  .validator({{ input }}Schema)
{% endif %}
  .handler(async ({ {% if operation == 'get' %}data{% else %}data{% endif %}) => {
    {% if auth %}
    const session = await getSession();
    if (!session) {
      throw new Error('Unauthorized');
    }
    {% endif %}
    {% if operation == 'list' %}
    return db.select().from({{ table }}).all();
    {% elif operation == 'get' %}
    return db.select().from({{ table }}).where(eq({{ table }}.id, data.id)).get();
    {% elif operation == 'create' %}
    return db.insert({{ table }}).values(data).returning().get();
    {% elif operation == 'update' %}
    return db.update({{ table }}).set(data).where(eq({{ table }}.id, data.id)).returning().get();
    {% elif operation == 'delete' %}
    return db.delete({{ table }}).where(eq({{ table }}.id, data.id)).run();
    {% endif %}
  });
