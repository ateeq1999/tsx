{
  "framework": "Drizzle ORM",
  "version": "1.0.0",
  "slug": "drizzle-orm",
  "category": "orm",
  "docs": "https://orm.drizzle.team",
  "github": "https://github.com/drizzle-team/drizzle-orm",
  "structure": {
    "root": ".",
    "src": "src",
    "db": "src/db",
    "queries": "src/queries"
  },
  "generators": [
    {
      "id": "schema",
      "description": "Create a database schema file"
    },
    {
      "id": "migration",
      "description": "Create a database migration"
    }
  ],
  "conventions": {
    "files": {
      "schema": {
        "pattern": "src/db/schema/{{kebabCase name}}.ts",
        "example": "src/db/schema/users.ts",
        "description": "Database schema definition"
      }
    },
    "naming": {
      "files": "kebab-case",
      "components": "PascalCase",
      "functions": "camelCase",
      "variables": "camelCase"
    },
    "patterns": [
      {
        "name": "Table Definition",
        "pattern": "export const {{camelCase name}} = pgTable('{{snakeCase name}}', { ... })",
        "description": "Drizzle table definition"
      }
    ]
  },
  "injection_points": [
    {
      "region": "schema",
      "marker": "// @tsx:schema:start",
      "end_marker": "// @tsx:schema:end",
      "description": "Schema injection"
    }
  ],
  "integrations": [
    {
      "package": "drizzle-kit",
      "install": "npm install drizzle-kit",
      "setup": [
        {
          "file": "drizzle.config.ts",
          "template": "drizzle.config.ts",
          "description": "Create Drizzle configuration"
        }
      ],
      "patterns": [
        {
          "name": "Migration",
          "pattern": "npx drizzle-kit push",
          "description": "Push schema to database"
        }
      ]
    }
  ],
  "questions": [
    {
      "topic": "how to add a table",
      "answer": "Create a schema file in src/db/schema/",
      "steps": [
        {
          "action": "Create schema file",
          "code": "touch src/db/schema/users.ts"
        },
        {
          "action": "Define columns",
          "description": "Use pgTable to define your table"
        }
      ],
      "files_affected": ["src/db/schema/*.ts"],
      "dependencies": ["drizzle-orm", "pg"]
    },
    {
      "topic": "how to run migrations",
      "answer": "Use drizzle-kit CLI",
      "steps": [
        {
          "action": "Push schema",
          "code": "npx drizzle-kit push"
        },
        {
          "action": "Generate migration",
          "code": "npx drizzle-kit generate"
        }
      ],
      "files_affected": ["drizzle.config.ts"],
      "dependencies": ["drizzle-kit"]
    }
  ]
}
