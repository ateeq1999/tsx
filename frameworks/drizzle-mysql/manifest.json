{
  "id": "drizzle-mysql",
  "name": "Drizzle ORM (MySQL)",
  "version": "1.0.0",
  "category": "orm",
  "description": "Drizzle ORM code patterns for MySQL — schema, migrations, and seed files.",
  "docs": "https://orm.drizzle.team/docs/get-started-mysql",
  "github": "https://github.com/drizzle-team/drizzle-orm",
  "peer_dependencies": {
    "drizzle-orm": "^0.36",
    "drizzle-kit": "^0.27",
    "mysql2": "^3.0"
  },
  "fpf_version": "1.1",
  "tsx_pkg_name": "@tsx-pkg/drizzle-mysql",
  "lang": ["typescript"],
  "runtime": ["node", "bun"],
  "tsx_min": "0.1.0",
  "provides": [
    "add:schema",
    "add:migration",
    "add:seed"
  ],
  "integrates_with": {
    "better-auth": {
      "slot": "auth_fields",
      "description": "Adds userId foreign key and createdAt/updatedAt timestamp fields to generated schemas"
    }
  },
  "generators": ["add-schema", "add-migration", "add-seed"],
  "template_format": "forge"
}
