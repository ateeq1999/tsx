{
  "id": "add-model",
  "command": "add:model",
  "description": "Add a GORM model struct with typed fields",
  "token_estimate": 25,
  "output_paths": [
    "internal/models/{{name | snake_case}}.go"
  ],
  "next_steps": [
    "Run `go run cmd/migrate/main.go` to apply the migration",
    "Register the model in your AutoMigrate call"
  ],
  "schema": {
    "type": "object",
    "required": ["name"],
    "properties": {
      "name": { "type": "string", "description": "Model struct name (e.g. 'User', 'Product')" },
      "table_name": { "type": "string", "description": "Database table name (default: snake_case plural)" },
      "timestamps": { "type": "boolean", "default": true, "description": "Embed gorm.Model (ID, CreatedAt, UpdatedAt, DeletedAt)" },
      "soft_delete": { "type": "boolean", "default": false, "description": "Include DeletedAt for soft-delete (included in gorm.Model)" }
    }
  }
}
