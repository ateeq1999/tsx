{
  "id": "add-page",
  "command": "add:page",
  "description": "Generate a TanStack Start route page component",
  "token_estimate": 20,
  "output_paths": ["routes/{{path}}/index.tsx"],
  "next_steps": [
    "Add a link to `<Link to=\"/{{path}}\" />` in your navigation component"
  ],
  "schema": {
    "type": "object",
    "required": ["path"],
    "properties": {
      "path": { "type": "string", "description": "Route path (e.g. 'dashboard', 'posts/$id')" },
      "auth": { "type": "boolean", "default": false, "description": "Wrap with auth guard" },
      "loader": { "type": "boolean", "default": false, "description": "Generate a route loader" }
    }
  }
}
