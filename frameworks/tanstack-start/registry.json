{
  "framework": "TanStack Start",
  "version": "1.0.0",
  "slug": "tanstack-start",
  "category": "framework",
  "docs": "https://tanstack.com/start",
  "github": "https://github.com/TanStack/start",
  "structure": {
    "root": ".",
    "src": "src",
    "routes": "src/routes",
    "components": "src/components",
    "lib": "src/lib",
    "config": "src/config"
  },
  "generators": [
    {
      "id": "atom",
      "description": "Create a UI atom component"
    },
    {
      "id": "molecule",
      "description": "Create a UI molecule component"
    },
    {
      "id": "layout",
      "description": "Create a route layout"
    },
    {
      "id": "feature",
      "description": "Create a feature with routes and components"
    }
  ],
  "conventions": {
    "files": {
      "atom": {
        "pattern": "src/components/atoms/{{kebabCase name}}.tsx",
        "example": "src/components/atoms/button.tsx",
        "description": "Atomic UI component"
      },
      "molecule": {
        "pattern": "src/components/molecules/{{kebabCase name}}.tsx",
        "example": "src/components/molecules/search-bar.tsx",
        "description": "Molecular UI component combining atoms"
      },
      "layout": {
        "pattern": "src/routes/{{kebabCase name}}.tsx",
        "example": "src/routes/dashboard.tsx",
        "description": "Route layout component"
      },
      "feature": {
        "pattern": "src/routes/{{kebabCase name}}/index.tsx",
        "example": "src/routes/users/index.tsx",
        "description": "Feature route"
      }
    },
    "naming": {
      "files": "kebab-case",
      "components": "PascalCase",
      "functions": "camelCase",
      "variables": "camelCase"
    },
    "patterns": [
      {
        "name": "Component Export",
        "pattern": "export { {{pascalCase name}} } from './{{kebabCase name}}'",
        "description": "Barrel export pattern"
      }
    ]
  },
  "injection_points": [
    {
      "region": "components",
      "marker": "// @tsx:components:start",
      "end_marker": "// @tsx:components:end",
      "description": "Component exports injection"
    },
    {
      "region": "routes",
      "marker": "// @tsx:routes:start",
      "end_marker": "// @tsx:routes:end",
      "description": "Route registration injection"
    }
  ],
  "integrations": [
    {
      "package": "@tanstack/react-router",
      "install": "npm install @tanstack/react-router",
      "setup": [
        {
          "file": "src/router.tsx",
          "template": "router.tsx",
          "description": "Create router configuration"
        }
      ],
      "patterns": [
        {
          "name": "Route Definition",
          "pattern": "createRoute({ getParentRoute: () => rootRoute, path: '/' })",
          "description": "Basic route definition"
        }
      ]
    }
  ],
  "questions": [
    {
      "topic": "how to add a new route",
      "answer": "Create a new file in src/routes/ using the feature generator",
      "steps": [
        {
          "action": "Generate feature",
          "code": "tsx generate feature users"
        },
        {
          "action": "Define route",
          "description": "Add your route path and component"
        }
      ],
      "files_affected": ["src/routes/*.tsx"],
      "dependencies": ["@tanstack/react-router"]
    },
    {
      "topic": "how to add a component",
      "answer": "Use the atom or molecule generator",
      "steps": [
        {
          "action": "Generate atom",
          "code": "tsx generate atom button"
        }
      ],
      "files_affected": ["src/components/atoms/*.tsx"],
      "dependencies": []
    }
  ]
}
