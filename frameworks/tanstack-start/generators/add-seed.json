{
  "id": "add-seed",
  "command": "add:seed",
  "description": "Generate a Drizzle database seed file",
  "token_estimate": 20,
  "schema": {
    "type": "object",
    "required": ["name"],
    "properties": {
      "name": { "type": "string", "description": "Table/entity name to seed" },
      "count": { "type": "number", "default": 10, "description": "Number of records to seed" }
    }
  }
}
