{
  "id": "todo-with-auth",
  "name": "Todo Feature with Auth",
  "version": "1.1.0",
  "description": "Full CRUD todo feature: Drizzle schema, Zod schemas, server functions (queries/mutations), list/detail routes with better-auth session guard, TanStack Form.",
  "author": "ateeg",
  "framework": "tanstack-start",
  "tags": ["tanstack-start", "drizzle", "crud", "auth", "form"],

  "args": [
    { "name": "name",       "type": "string",  "required": true,              "description": "Entity name, singular (e.g. todo, task, note)" },
    { "name": "has_done",   "type": "bool",    "required": false, "default": true,         "description": "Add a boolean done/completed field" },
    { "name": "has_due",    "type": "bool",    "required": false, "default": false,        "description": "Add a due_date timestamp field" },
    { "name": "auth_guard", "type": "string",  "required": false, "default": "_protected", "description": "Auth layout route prefix in TanStack Router" }
  ],

  "outputs": [
    { "id": "schema",       "template": "schema.forge",      "path": "src/db/schema/{{ name | snake_case }}.ts" },
    { "id": "zod-schema",   "template": "zod-schema.forge",  "path": "src/schemas/{{ name | snake_case }}.ts" },
    { "id": "queries",      "template": "queries.forge",     "path": "src/server-fns/{{ name | snake_case }}/queries.ts" },
    { "id": "mutations",    "template": "mutations.forge",   "path": "src/server-fns/{{ name | snake_case }}/mutations.ts" },
    { "id": "list-route",   "template": "list-route.forge",  "path": "src/routes/{{ auth_guard }}/{{ name | snake_case }}/index.tsx" },
    { "id": "detail-route", "template": "detail-route.forge","path": "src/routes/{{ auth_guard }}/{{ name | snake_case }}/$id.tsx" },
    { "id": "form",         "template": "form.forge",         "path": "src/components/{{ name | snake_case }}/{{ name | pascal_case }}Form.tsx" }
  ],

  "commands": {
    "all": {
      "description": "Generate complete feature (schema, Zod, server fns, routes, form)",
      "outputs": ["schema", "zod-schema", "queries", "mutations", "list-route", "detail-route", "form"],
      "default": true
    },
    "schema": {
      "description": "Drizzle table + Zod schemas only",
      "outputs": ["schema", "zod-schema"]
    },
    "api": {
      "description": "Server functions (queries + mutations) only",
      "outputs": ["queries", "mutations"]
    },
    "routes": {
      "description": "List route and detail route only",
      "outputs": ["list-route", "detail-route"]
    },
    "form": {
      "description": "TanStack Form component only",
      "outputs": ["form"]
    }
  },

  "markers": [
    {
      "marker": "// [tsx:schemas]",
      "file": "src/db/schema/index.ts",
      "insert": "export * from './{{ name | snake_case }}';"
    },
    {
      "marker": "// [tsx:server-fns]",
      "file": "src/server-fns/index.ts",
      "insert": "export * from './{{ name | snake_case }}/queries';"
    },
    {
      "marker": "// [tsx:server-fns]",
      "file": "src/server-fns/index.ts",
      "insert": "export * from './{{ name | snake_case }}/mutations';"
    }
  ],

  "post_hooks": {
    "all":    ["bun run db:push"],
    "schema": ["bun run db:push"]
  }
}
