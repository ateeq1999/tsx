{
  "id": "better-auth",
  "name": "Better Auth",
  "description": "Authentication patterns for TanStack Start using Better Auth.",
  "category": "auth",
  "author": "better-auth",
  "license": "MIT",
  "docs": "https://www.better-auth.com",
  "github": "https://github.com/better-auth/better-auth",
  "npm_packages": [
    "better-auth"
  ],
  "commands": [
    {
      "id": "add:auth",
      "description": "Set up Better Auth configuration",
      "template": "auth_setup.jinja"
    },
    {
      "id": "add:auth-guard",
      "description": "Wrap a route with a session guard",
      "template": "auth_guard.jinja"
    }
  ],
  "peer_packages": [
    "@tanstack/start"
  ],
  "tags": [
    "auth",
    "authentication",
    "session"
  ],
  "version": "1.0.0",
  "stacks": {},
  "template_format": "jinja",
  "tsx_min": "0.1.0"
}