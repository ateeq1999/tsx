{
  "id": "add-ui-input",
  "command": "add:ui-input",
  "description": "Add a shadcn/ui Input component to your project",
  "token_estimate": 15,
  "output_paths": [
    "components/ui/input.tsx"
  ],
  "next_steps": [
    "Import and use the Input component in your forms"
  ],
  "schema": {
    "type": "object",
    "properties": {
      "type": {
        "type": "string",
        "enum": ["text", "email", "password", "number", "search", "tel", "url"],
        "default": "text"
      }
    }
  }
}
