{
  "id": "add-ui-form",
  "command": "add:ui-form",
  "description": "Add a complete form with shadcn/ui components",
  "token_estimate": 30,
  "output_paths": [
    "components/{{name}}Form.tsx"
  ],
  "next_steps": [
    "Connect form to server function",
    "Add validation rules"
  ],
  "schema": {
    "type": "object",
    "required": ["name"],
    "properties": {
      "name": { "type": "string", "description": "Form component name (e.g. 'Todo', 'User')" },
      "fields": {
        "type": "array",
        "items": {
          "type": "object",
          "required": ["name", "type"],
          "properties": {
            "name": { "type": "string" },
            "type": { "type": "string", "enum": ["text", "email", "password", "number", "select", "textarea", "checkbox"] },
            "label": { "type": "string" },
            "placeholder": { "type": "string" }
          }
        }
      }
    }
  }
}
