# ── tsx Registry Server — Environment Variables ────────────────────────
# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# Required — PostgreSQL connection string (Neon, Supabase, or any Postgres)
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Optional — Port to listen on (default: 8282)
# Render, Railway, and Koyeb inject this automatically.
PORT=8282

# Optional — Bearer token for admin endpoints (/v1/admin/*) and publish auth.
# If unset, admin endpoints require no auth (dev mode only — set this in prod!).
TSX_REGISTRY_API_KEY=your-secret-api-key-here

# Optional — Directory to store uploaded tarballs (default: ./data)
# On Render/Koyeb use /tmp/tsx-data since the filesystem is ephemeral.
DATA_DIR=/tmp/tsx-data

# Optional — Log level filter (default: tsx_registry=info,tower_http=info)
RUST_LOG=tsx_registry=info,tower_http=info
