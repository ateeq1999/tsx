{
  "id": "add-handler",
  "command": "add:handler",
  "description": "Add Axum route handlers (list, get, create, update, delete) for a resource",
  "token_estimate": 45,
  "output_paths": [
    "src/handlers/{{name | snake_case}}.rs"
  ],
  "next_steps": [
    "Register handlers in your Axum router in `src/main.rs`",
    "Add middleware (auth, rate-limit) as needed"
  ],
  "schema": {
    "type": "object",
    "required": ["name"],
    "properties": {
      "name": { "type": "string", "description": "Resource name (e.g. 'User', 'Post')" },
      "auth": { "type": "boolean", "default": false, "description": "Extract and validate JWT claims in handlers" },
      "operations": {
        "type": "array",
        "items": { "type": "string", "enum": ["list", "get", "create", "update", "delete"] },
        "default": ["list", "get", "create", "update", "delete"]
      }
    }
  }
}
