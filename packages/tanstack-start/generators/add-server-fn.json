{
  "id": "add-server-fn",
  "command": "add:server-fn",
  "description": "Generate a typed TanStack Start server function",
  "token_estimate": 25,
  "output_paths": ["server-functions/{{name}}.ts"],
  "init_once": ["src/server-fns/index.ts"],
  "markers": [
    {
      "marker": "// [tsx:server-fns]",
      "file": "src/server-fns/index.ts",
      "insert": "export * from './{{name}}';"
    }
  ],
  "next_steps": [
    "Run `tsx run add-query --json '{\"name\":\"{{name}}\"}' ` to create a query hook that calls this function"
  ],
  "schema": {
    "type": "object",
    "required": ["name"],
    "properties": {
      "name": { "type": "string", "description": "Function name (camelCase)" },
      "method": { "type": "string", "enum": ["GET", "POST", "PUT", "DELETE", "PATCH"], "default": "POST" },
      "input_type": { "type": "string", "description": "TypeScript input type (e.g. z.object({...}))" },
      "return_type": { "type": "string", "description": "TypeScript return type" },
      "auth": { "type": "boolean", "default": false, "description": "Require authentication" }
    }
  }
}
